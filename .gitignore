
# Terraform state files — contain sensitive infrastructure data
terraform.tfstate
terraform.tfstate.backup
.terraform.tfstate.lock.info

# Terraform working directory — downloaded providers (very large)
.terraform/

# Terraform plan output files
*.tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Sensitive variable files — never commit these
*.tfvars
*.tfvars.json

# macOS
.DS_Store

# VS Code
.vscode/

